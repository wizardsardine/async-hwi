# Pinned versions for the Ledger speculos flow. Sourced by both
# .github/workflows/main.yml and tests/speculos/run.sh; keep this as the
# single source of truth so a bump invalidates the CI cache and the local
# cache identically.
LEDGER_APP_VERSION=2.4.6
LEDGER_APP_BUILDER_IMAGE=ghcr.io/ledgerhq/ledger-app-builder/ledger-app-builder:5.3.2
SPECULOS_VERSION=0.26.6
